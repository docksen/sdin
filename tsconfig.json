{
  "include": ["src"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "checkJs": false,
    "strict": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "lib": ["ESNext", "DOM"],
    "module": "CommonJS",
    "target": "ES5",
    "jsx": "react",
    "outDir": "dist",
    "allowJs": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "sourceMap": true,
    "declaration": false,
    "declarationMap": false,
    "removeComments": false,
    "baseUrl": ".",
    "paths": {
      "api/*": ["src/api/*"],
      "bin/*": ["src/bin/*"],
      "core/*": ["src/core/*"],
      "main/*": ["src/main/*"],
      "utils/*": ["src/utils/*"]
    }
  }
}
